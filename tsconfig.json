  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["supabase/functions/**/*.ts", "supabase/functions/**/*.d.ts"]
}
